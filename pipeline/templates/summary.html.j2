<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>$page_title</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f5f1e8;
        --panel: rgba(255, 252, 247, 0.96);
        --ink: #1d1b16;
        --muted: #645b4d;
        --line: rgba(29, 27, 22, 0.12);
        --accent: #d55d3d;
        --accent-soft: rgba(213, 93, 61, 0.12);
        --shadow: 0 18px 40px rgba(25, 18, 9, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, rgba(255, 215, 150, 0.5), transparent 28%),
          linear-gradient(180deg, #fff9f0 0%, var(--bg) 100%);
        color: var(--ink);
        font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", serif;
      }

      main {
        width: min(1100px, calc(100vw - 32px));
        margin: 0 auto;
        padding: 40px 0 64px;
      }

      .hero {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 28px;
        padding: 28px;
        box-shadow: var(--shadow);
      }

      .eyebrow {
        display: inline-flex;
        gap: 10px;
        padding: 8px 12px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent);
        font-size: 13px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1 {
        margin: 16px 0 10px;
        font-size: clamp(32px, 5vw, 52px);
        line-height: 1.05;
      }

      .hero p {
        margin: 0;
        color: var(--muted);
        font-size: 16px;
        line-height: 1.55;
      }

      .meta {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 14px;
        margin-top: 24px;
      }

      .meta-item {
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 14px 16px;
        background: rgba(255, 255, 255, 0.72);
      }

      .meta-item strong {
        display: block;
        margin-bottom: 6px;
        font-size: 12px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .meta-item span,
      .meta-item a {
        color: var(--ink);
        text-decoration: none;
        word-break: break-word;
      }

      .cards {
        display: grid;
        gap: 20px;
        margin-top: 28px;
      }

      .card {
        display: grid;
        grid-template-columns: minmax(220px, 320px) 1fr;
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 26px;
        background: var(--panel);
        box-shadow: var(--shadow);
      }

      .card-image {
        width: 100%;
        height: 100%;
        min-height: 220px;
        object-fit: cover;
        background: #e8dece;
      }

      .card-image--empty {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: 14px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .card-body {
        padding: 24px;
      }

      .card-index {
        color: var(--accent);
        font-size: 13px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .card h2 {
        margin: 8px 0 10px;
        font-size: 28px;
      }

      .card-time,
      .card-metrics,
      .card-source,
      .card-notes,
      .card-shot {
        margin: 0;
        color: var(--muted);
        line-height: 1.6;
      }

      .card-source,
      .card-metrics,
      .card-notes,
      .card-shot {
        margin-top: 10px;
      }

      @media (max-width: 780px) {
        main {
          width: min(100vw - 20px, 720px);
          padding-top: 20px;
        }

        .hero,
        .card-body {
          padding: 20px;
        }

        .card {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="hero">
        <div class="eyebrow">Workout Summary <span>$step_count steps</span></div>
        <h1>$video_title</h1>
        <p>Generated from a YouTube workout video using transcript-guided step extraction and frame capture.</p>
        <div class="meta">
          <div class="meta-item">
            <strong>Total Duration</strong>
            <span>$total_duration</span>
          </div>
          <div class="meta-item">
            <strong>Language</strong>
            <span>$language</span>
          </div>
          <div class="meta-item">
            <strong>Transcript Source</strong>
            <span>$transcript_source</span>
          </div>
          <div class="meta-item">
            <strong>Source</strong>
            <a href="$source_url">$source_url</a>
          </div>
          <div class="meta-item">
            <strong>Generated At</strong>
            <span>$generated_at</span>
          </div>
        </div>
      </section>

      <section class="cards">
        $cards
      </section>
    </main>
  </body>
</html>
